            </div>

            <div style={{ background:"#f8fafc", borderRadius:8, padding:"8px 10px",
              marginBottom:6, borderLeft:`3px solid ${c.color}` }}>
              <span style={{ fontFamily:"'Nunito'", fontSize:10, fontWeight:700,
                color:"#16a34a", textTransform:"uppercase", letterSpacing:"0.06em" }}>✓ Strength  </span>
              <span style={{ fontFamily:"'Nunito'", fontSize:11, color:"#475569" }}>{c.strength}</span>
            </div>
            <div style={{ background:"#fff5f7", borderRadius:8, padding:"8px 10px",
              borderLeft:"3px solid #fda4af" }}>
              <span style={{ fontFamily:"'Nunito'", fontSize:10, fontWeight:700,
                color:"#be123c", textTransform:"uppercase", letterSpacing:"0.06em" }}>⚠ Watch  </span>
              <span style={{ fontFamily:"'Nunito'", fontSize:11, color:"#475569" }}>{c.watch}</span>
            </div>
          </div>
        ))}
      </div>

      {/* Pipeline diagram */}
      <div style={{ background:"#f8fafc", border:"1.5px solid #e2e8f0", borderRadius:14,
        padding:"16px 20px" }}>
        <div style={{ fontFamily:"'Nunito'", fontSize:10, fontWeight:700, color:"#94a3b8",
          textTransform:"uppercase", letterSpacing:"0.1em", marginBottom:10 }}>
          How they fit in a real eval pipeline
        </div>
        <div style={{ display:"flex", alignItems:"center", gap:0, flexWrap:"wrap" }}>
          {["Model\nOutput","→","Verifier\n(factual/code)","→","Judge\n(quality)","→","Aggregate\nMetrics","→","Dashboard\n& Alerts"].map((s,i) => (
            s === "→"
              ? <div key={i} style={{ color:"#94a3b8", fontSize:16, padding:"0 4px" }}>→</div>
              : <div key={i} style={{ background:"white", border:"1.5px solid #e2e8f0",
                  borderRadius:8, padding:"6px 10px", textAlign:"center",
                  fontFamily:"'Nunito'", fontSize:11, fontWeight:600, color:"#475569",
                  lineHeight:1.4, whiteSpace:"pre-line" }}>{s}</div>
          ))}
        </div>
      </div>
    </div>
  );
}

/* ─── JUDGE TAB ─── */
function JudgeTab() {
  const [taskId, setTaskId] = useState("gradient");
  const [responseId, setResponseId] = useState(null);
  const [judging, setJudging] = useState(false);
  const [result, setResult] = useState(null);
  const [showPrompt, setShowPrompt] = useState(false);
  const resultRef = useRef(null);

  const task = TASKS.find(t => t.id === taskId);

  function handleTaskChange(id) {
    setTaskId(id); setResponseId(null); setResult(null); setShowPrompt(false);
  }

  function handleJudge() {
    if (!responseId) return;
    setJudging(true); setResult(null); setShowPrompt(false);
    setTimeout(() => {
      setJudging(false);
      setResult(task.judgements[responseId]);
      setTimeout(() => resultRef.current?.scrollIntoView({ behavior:"smooth", block:"nearest" }), 100);
    }, 1800);
  }

  const selectedResponse = task.responses.find(r => r.id === responseId);

  const qualityColor = { good:"#16a34a", mediocre:"#b45309", bad:"#be123c" };
  const qualityPale  = { good:"#f0fdf4", mediocre:"#fffbeb", bad:"#fff5f7" };
  const accentColor  = "#6366f1";

  const judgePrompt = responseId ? `SYSTEM: You are an expert evaluator. Score the response below.

TASK GIVEN TO MODEL:
"${task.prompt}"

MODEL RESPONSE:
"${selectedResponse?.text?.slice(0,120)}..."

RUBRIC — score each criterion 1 (very poor) to 5 (excellent):
${task.rubric.map(r => `- ${r}`).join('\n')}

Return ONLY valid JSON:
{
  "scores": {${task.rubric.map(r=>`"${r}": <int>`).join(', ')}},
  "overall": <float>,
  "reasoning": "<2–3 sentences>",
  "verdict": "Pass" | "Borderline" | "Fail"
}` : "";

  return (
    <div>
      {/* Task selector */}
      <div style={{ marginBottom:16 }}>
        <div style={{ fontFamily:"'Nunito'", fontSize:10, fontWeight:700, color:"#6366f1",
          textTransform:"uppercase", letterSpacing:"0.07em", marginBottom:8 }}>1 · Choose a task</div>
        <div style={{ display:"flex", gap:8 }}>
          {TASKS.map(t => (
            <button key={t.id} onClick={() => handleTaskChange(t.id)} style={{
              background: taskId===t.id ? "#e0e7ff" : "white",
              border: `${taskId===t.id?2:1.5}px solid ${taskId===t.id?"#a5b4fc":"#e2e8f0"}`,
              borderRadius:10, padding:"8px 14px", cursor:"pointer",
              fontFamily:"'Nunito'", fontSize:12, fontWeight:600,
              color: taskId===t.id ? "#6366f1" : "#64748b", transition:"all .18s"
            }}>{t.label}</button>
          ))}
        </div>
      </div>

      {/* Response selector */}
      <div style={{ marginBottom:16 }}>
        <div style={{ fontFamily:"'Nunito'", fontSize:10, fontWeight:700, color:"#6366f1",
          textTransform:"uppercase", letterSpacing:"0.07em", marginBottom:8 }}>2 · Pick a model response to evaluate</div>
        <div style={{ display:"grid", gridTemplateColumns:"repeat(3,1fr)", gap:10 }}>
          {task.responses.map(r => {
            const qc = qualityColor[r.quality]; const qp = qualityPale[r.quality];
            const active = responseId === r.id;
            return (
              <button key={r.id} onClick={() => { setResponseId(r.id); setResult(null); }} style={{
                background: active ? qp : "white",
                border: `${active?2:1.5}px solid ${active?qc+"80":"#e2e8f0"}`,
                borderRadius:12, padding:"10px 12px", cursor:"pointer",
                textAlign:"left", transition:"all .18s",
                boxShadow: active ? `0 0 0 2px ${qc}22` : "none"
              }}>
                <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:6 }}>
                  <span style={{ fontFamily:"'Nunito'", fontSize:12, fontWeight:700, color:"#1e293b" }}>{r.label}</span>
                  <span style={{ fontFamily:"'Nunito'", fontSize:10, fontWeight:700, color:qc,
                    background:qp, borderRadius:20, padding:"2px 8px",
                    border:`1px solid ${qc}50` }}>{r.badge}</span>
                </div>
                <div style={{ fontFamily:"'Nunito'", fontSize:11, color:"#64748b", lineHeight:1.5,
                  display:"-webkit-box", WebkitLineClamp:3, WebkitBoxOrient:"vertical",
                  overflow:"hidden", whiteSpace:"pre-wrap" }}>{r.text}</div>
              </button>
            );
          })}
        </div>
      </div>

      {/* Judge prompt preview */}
      {responseId && (
        <div style={{ marginBottom:14 }}>
          <button onClick={() => setShowPrompt(p => !p)} style={{
            background:"transparent", border:"none", cursor:"pointer",
            fontFamily:"'Nunito'", fontSize:11, fontWeight:600, color:"#6366f1",
            display:"flex", alignItems:"center", gap:5, padding:0 }}>
            <span>{showPrompt?"▾":"▸"}</span> {showPrompt?"Hide":"Show"} judge prompt
          </button>
          {showPrompt && (
            <div className="slide" style={{ marginTop:8, background:"#1e293b", borderRadius:10,
              padding:"14px 16px", fontFamily:"'Courier New',monospace", fontSize:11,
              color:"#e2e8f0", lineHeight:1.7, whiteSpace:"pre-wrap", wordBreak:"break-word" }}>
              {judgePrompt}
            </div>
          )}
        </div>
      )}

      {/* Judge button */}
      <button onClick={handleJudge} disabled={!responseId || judging} style={{
        background: responseId && !judging
          ? "linear-gradient(135deg,#6366f1,#0d9488)"
          : "#e2e8f0",
        border:"none", borderRadius:10, padding:"11px 24px",
        fontFamily:"'Nunito'", fontSize:13, fontWeight:700,
        color: responseId && !judging ? "white" : "#94a3b8",
        cursor: responseId && !judging ? "pointer" : "not-allowed",
        transition:"all .2s", marginBottom:16,
        display:"flex", alignItems:"center", gap:8 }}>
        {judging
          ? <><span className="spin">⚙</span> Judging…</>
          : <>⚖ Judge this response</>}
      </button>

      {/* Judging animation */}
      {judging && (
        <div style={{ background:"#e0e7ff", border:"1.5px solid #a5b4fc", borderRadius:12,
          padding:"14px 16px", marginBottom:16 }}>
          {["Parsing rubric criteria…","Evaluating accuracy…","Checking clarity & helpfulness…","Computing scores…"].map((s,i) => (
            <div key={s} className="pulse" style={{ fontFamily:"'Nunito'", fontSize:12,
              color:"#6366f1", marginBottom:4,
              animationDelay:`${i*0.35}s`, lineHeight:1.5 }}>
              ◦ {s}
            </div>
          ))}
        </div>
      )}

      {/* Results */}
      {result && (
        <div ref={resultRef} className="slide">
          <div style={{ background:"white", border:"1.5px solid #e2e8f0", borderRadius:14,
            padding:"18px 18px" }}>
            <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center",
              marginBottom:14 }}>
              <div style={{ fontFamily:"'Cormorant Garamond'", fontStyle:"italic",
                fontSize:18, fontWeight:600, color:"#1e293b" }}>Judge Verdict</div>
              <div style={{ display:"flex", alignItems:"center", gap:10 }}>
                <div style={{ fontFamily:"'Cormorant Garamond'", fontSize:28, fontWeight:700,
                  color:accentColor }}>{result.overall.toFixed(2)}<span style={{ fontSize:14,
                  color:"#94a3b8", fontFamily:"'Nunito'" }}>/5</span></div>
                <VerdictBadge verdict={result.verdict} />
              </div>
            </div>

            {/* Per-dimension scores */}
            <div style={{ marginBottom:14 }}>
              <div style={{ fontFamily:"'Nunito'", fontSize:10, fontWeight:700,
                textTransform:"uppercase", letterSpacing:"0.07em", color:accentColor,
                marginBottom:8 }}>Dimension Scores</div>
              {task.rubric.map((dim, i) => (
                <div key={dim} style={{ display:"flex", alignItems:"center", gap:10, marginBottom:7 }}>
                  <div style={{ fontFamily:"'Nunito'", fontSize:12, fontWeight:600,
                    color:"#475569", width:110, flexShrink:0 }}>{dim}</div>
                  <ScoreBar score={result.scores[i]} color={accentColor} />
                  <div style={{ fontFamily:"'Cormorant Garamond'", fontSize:16, fontWeight:700,
                    color:accentColor, width:24, textAlign:"right", flexShrink:0 }}>
                    {result.scores[i]}
                  </div>
                </div>
              ))}
            </div>

            {/* Reasoning */}
            <div style={{ background:"#f8fafc", borderRadius:10, padding:"12px 14px",
              borderLeft:"4px solid #6366f1" }}>
              <div style={{ fontFamily:"'Nunito'", fontSize:10, fontWeight:700,
                color:"#6366f1", textTransform:"uppercase", letterSpacing:"0.07em",
                marginBottom:6 }}>Reasoning</div>
              <div style={{ fontFamily:"'Cormorant Garamond'", fontStyle:"italic",
                fontSize:14, color:"#1e293b", lineHeight:1.7 }}>"{result.reasoning}"</div>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}

/* ─── VERIFIER TAB ─── */
function VerifierTab() {
  const [selected, setSelected] = useState("factual");
  const [verifying, setVerifying] = useState(false);
  const [result, setResult] = useState(null);
  const [showPrompt, setShowPrompt] = useState(false);
  const resultRef = useRef(null);

  const ex = VERIFIER_EXAMPLES.find(e => e.id === selected);

  function handleSelect(id) { setSelected(id); setResult(null); setShowPrompt(false); }

  function handleVerify() {
    setVerifying(true); setResult(null);
    setTimeout(() => {
      setVerifying(false); setResult(ex);
      setTimeout(() => resultRef.current?.scrollIntoView({ behavior:"smooth", block:"nearest" }), 80);
    }, 1500);
  }

  return (
    <div>
      {/* Type selector */}
      <div style={{ marginBottom:16 }}>
        <div style={{ fontFamily:"'Nunito'", fontSize:10, fontWeight:700, color:"#0d9488",
          textTransform:"uppercase", letterSpacing:"0.07em", marginBottom:8 }}>
          1 · Choose a claim type
        </div>
        <div style={{ display:"flex", gap:8 }}>
          {VERIFIER_EXAMPLES.map(e => (
            <button key={e.id} onClick={() => handleSelect(e.id)} style={{
              background: selected===e.id ? e.pale : "white",
              border: `${selected===e.id?2:1.5}px solid ${selected===e.id?e.border:"#e2e8f0"}`,
              borderRadius:10, padding:"8px 14px", cursor:"pointer",
              fontFamily:"'Nunito'", fontSize:12, fontWeight:600,
              color: selected===e.id ? e.color : "#64748b", transition:"all .18s",
              display:"flex", alignItems:"center", gap:6
            }}>
              {e.icon} {e.type}
            </button>
          ))}
        </div>
      </div>

      {/* Claim display */}
      <div style={{ marginBottom:14 }}>
        <div style={{ fontFamily:"'Nunito'", fontSize:10, fontWeight:700, color:"#0d9488",
          textTransform:"uppercase", letterSpacing:"0.07em", marginBottom:8 }}>2 · Claim to verify</div>
        <div style={{ background:ex.pale, border:`1.5px solid ${ex.border}`,
          borderRadius:12, padding:"14px 16px" }}>
          <div style={{ fontFamily:"'Cormorant Garamond'", fontStyle:"italic",
            fontSize:15, color:"#1e293b", lineHeight:1.7, whiteSpace:"pre-wrap" }}>
            "{ex.claim}"
          </div>
        </div>
      </div>

      {/* Prompt preview */}
      <div style={{ marginBottom:14 }}>
        <button onClick={() => setShowPrompt(p => !p)} style={{
          background:"transparent", border:"none", cursor:"pointer",
          fontFamily:"'Nunito'", fontSize:11, fontWeight:600, color:ex.color,
          display:"flex", alignItems:"center", gap:5, padding:0 }}>
          <span>{showPrompt?"▾":"▸"}</span> {showPrompt?"Hide":"Show"} verification prompt
        </button>
        {showPrompt && (
          <div className="slide" style={{ marginTop:8, background:"#1e293b", borderRadius:10,
            padding:"14px 16px", fontFamily:"'Courier New',monospace", fontSize:11,
            color:"#e2e8f0", lineHeight:1.7, whiteSpace:"pre-wrap", wordBreak:"break-word" }}>
            {ex.prompt}
          </div>
        )}
      </div>

      {/* Verify button */}
      <button onClick={handleVerify} disabled={verifying} style={{
        background: !verifying
          ? `linear-gradient(135deg, ${ex.color}, #6366f1)`
          : "#e2e8f0",
        border:"none", borderRadius:10, padding:"11px 24px",
        fontFamily:"'Nunito'", fontSize:13, fontWeight:700,
        color: !verifying ? "white" : "#94a3b8",
        cursor: !verifying ? "pointer" : "not-allowed",
        transition:"all .2s", marginBottom:16,
        display:"flex", alignItems:"center", gap:8 }}>
        {verifying ? <><span className="spin">⚙</span> Verifying…</> : <>{ex.icon} Verify this claim</>}
      </button>

      {verifying && (
        <div style={{ background:ex.pale, border:`1.5px solid ${ex.border}`, borderRadius:12,
          padding:"14px 16px", marginBottom:16 }}>
          {["Parsing claim…","Checking against knowledge…","Computing confidence…"].map((s,i) => (
            <div key={s} className="pulse" style={{ fontFamily:"'Nunito'", fontSize:12,
              color:ex.color, marginBottom:4, animationDelay:`${i*0.4}s`, lineHeight:1.5 }}>
              ◦ {s}
            </div>
          ))}
        </div>
      )}

      {result && (
        <div ref={resultRef} className="slide">
          <div style={{ background:"white", border:"1.5px solid #e2e8f0", borderRadius:14,
            padding:"18px 18px" }}>
            <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center",
              marginBottom:14 }}>
              <div style={{ fontFamily:"'Cormorant Garamond'", fontStyle:"italic",
                fontSize:18, fontWeight:600, color:"#1e293b" }}>Verification Result</div>
              <div style={{ display:"flex", alignItems:"center", gap:10 }}>
                <div style={{ fontFamily:"'Nunito'", fontSize:11, color:"#94a3b8" }}>
                  Confidence: <span style={{ fontWeight:700, color:"#1e293b" }}>{result.confidence}%</span>
                </div>
                <VerdictBadge verdict={result.verdict} />
              </div>
            </div>

            {/* Confidence bar */}
            <div style={{ marginBottom:14 }}>
              <div style={{ fontFamily:"'Nunito'", fontSize:10, fontWeight:700, color:ex.color,
                textTransform:"uppercase", letterSpacing:"0.07em", marginBottom:6 }}>Confidence</div>
              <div style={{ display:"flex", alignItems:"center", gap:10 }}>
                <ScoreBar score={(result.confidence/100)*5} color={ex.color} />
                <span style={{ fontFamily:"'Cormorant Garamond'", fontSize:20, fontWeight:700,
                  color:ex.color, flexShrink:0 }}>{result.confidence}%</span>
              </div>
            </div>

            <div style={{ background:"#f8fafc", borderRadius:10, padding:"12px 14px",
              borderLeft:`4px solid ${ex.color}` }}>
              <div style={{ fontFamily:"'Nunito'", fontSize:10, fontWeight:700,
                color:ex.color, textTransform:"uppercase", letterSpacing:"0.07em",
                marginBottom:6 }}>Reasoning</div>
              <div style={{ fontFamily:"'Cormorant Garamond'", fontStyle:"italic",
                fontSize:14, color:"#1e293b", lineHeight:1.7 }}>"{result.reasoning}"</div>
            </div>

            {/* Reference */}
            <div style={{ marginTop:12, background:"#f0fdfa", border:"1px solid #5eead4",
              borderRadius:8, padding:"8px 12px" }}>
              <span style={{ fontFamily:"'Nunito'", fontSize:10, fontWeight:700,
                color:"#0d9488", textTransform:"uppercase", letterSpacing:"0.06em" }}>Ground truth  </span>
              <span style={{ fontFamily:"'Nunito'", fontSize:11, color:"#475569" }}>
                {result.reference}
              </span>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}

/* ─── CODE TAB ─── */
function CodeTab() {
  const [sub, setSub] = useState("judge");
  const tabs = [
    ["judge","Judge Prompt"],["pairwise","Pairwise A/B"],
    ["verifier","Verifier"],["tips","Tips & Pitfalls"]
  ];
  return (
    <div>
      <div style={{ display:"flex", gap:4, marginBottom:18, background:"#eef6f9",
        borderRadius:10, padding:4, border:"1px solid #e2e8f0", width:"fit-content", flexWrap:"wrap" }}>
        {tabs.map(([k,l]) => (
          <button key={k} onClick={() => setSub(k)} style={{
            background: sub===k ? "white" : "transparent",
            border:"none", borderRadius:8, padding:"6px 13px", cursor:"pointer",
            fontFamily:"'Nunito'", fontSize:12, fontWeight:600,
            color: sub===k ? "#6366f1" : "#64748b",
            boxShadow: sub===k ? "0 4px 24px rgba(99,102,241,0.08)" : "none",
            transition:"all .18s" }}>{l}</button>
        ))}
      </div>
      <pre dangerouslySetInnerHTML={{ __html: CODE_SNIPPETS[sub] }} />
      <div style={{ marginTop:10, fontFamily:"'Nunito'", fontSize:11, color:"#94a3b8", textAlign:"right" }}>
        Uses the Anthropic Python SDK · pip install anthropic
      </div>
    </div>
  );
}

