const CODE_SNIPPETS = {
  judge:`<span class="cm"># ── LLM-as-a-Judge: basic pattern ──────────────────────────────</span>
<span class="kw">import</span> anthropic, json

client = anthropic.Anthropic()

<span class="kw">def</span> <span class="fn">build_judge_prompt</span>(task, response, rubric):
    criteria = <span class="str">"\n"</span>.join(
        <span class="str">f"- {r}: score 1 (very poor) to 5 (excellent)"</span>
        <span class="kw">for</span> r <span class="kw">in</span> rubric
    )
    <span class="kw">return</span> <span class="str">f"""You are an expert evaluator. Score the response below.

TASK GIVEN TO MODEL:
{task}

MODEL RESPONSE:
{response}

RUBRIC — score each criterion 1–5:
{criteria}

Return ONLY valid JSON:
{{
  "scores": {{{", ".join(f'"{r}": <int>' for r in rubric)}}},
  "overall": <float>,
  "reasoning": "<2–3 sentences>",
  "verdict": "Pass" | "Borderline" | "Fail"
}}"""</span>

<span class="kw">def</span> <span class="fn">judge_response</span>(task, response, rubric):
    prompt = build_judge_prompt(task, response, rubric)

    msg = client.messages.create(
        model=<span class="str">"claude-opus-4-8"</span>,
        max_tokens=<span class="num">512</span>,
        messages=[{<span class="str">"role"</span>: <span class="str">"user"</span>, <span class="str">"content"</span>: prompt}]
    )
    <span class="kw">return</span> json.loads(msg.content[<span class="num">0</span>].text)

<span class="cm"># ── Example usage ───────────────────────────────────────────────</span>
task     = <span class="str">"Explain gradient descent to a beginner."</span>
response = <span class="str">"Imagine you're blindfolded in hilly terrain..."</span>
rubric   = [<span class="str">"Accuracy"</span>, <span class="str">"Clarity"</span>, <span class="str">"Helpfulness"</span>, <span class="str">"Conciseness"</span>]

result = judge_response(task, response, rubric)
<span class="cm"># → {"scores": {"Accuracy": 5, "Clarity": 5, ...}, "overall": 4.75, ...}</span>`,

  pairwise:`<span class="cm"># ── Pairwise Comparison (A/B judge) ─────────────────────────────</span>
<span class="cm"># Better than absolute scoring for comparing two model outputs</span>

<span class="kw">def</span> <span class="fn">pairwise_judge</span>(task, response_a, response_b):
    prompt = <span class="str">f"""Compare two responses to the same task.

TASK: {task}

RESPONSE A:
{response_a}

RESPONSE B:
{response_b}

Which response is better overall, and why?
Return JSON:
{{
  "winner": "A" | "B" | "tie",
  "confidence": <"high"|"medium"|"low">,
  "reasoning": "<key differences>"
}}"""</span>

    msg = client.messages.create(
        model=<span class="str">"claude-opus-4-8"</span>,
        max_tokens=<span class="num">300</span>,
        messages=[{<span class="str">"role"</span>: <span class="str">"user"</span>, <span class="str">"content"</span>: prompt}]
    )
    <span class="kw">return</span> json.loads(msg.content[<span class="num">0</span>].text)

<span class="cm"># ── Run multiple comparisons to reduce position bias ─────────────</span>
<span class="cm"># Always run (A vs B) AND (B vs A), then aggregate</span>
<span class="kw">def</span> <span class="fn">robust_pairwise</span>(task, response_a, response_b, n=<span class="num">3</span>):
    results = []
    <span class="kw">for</span> _ <span class="kw">in</span> range(n):
        ab = pairwise_judge(task, response_a, response_b)
        ba = pairwise_judge(task, response_b, response_a)
        <span class="cm"># Flip B-A result to normalise</span>
        ba_normalised = {<span class="str">"winner"</span>: <span class="str">"A"</span> <span class="kw">if</span> ba[<span class="str">"winner"</span>] == <span class="str">"B"</span>
                         <span class="kw">else</span> (<span class="str">"B"</span> <span class="kw">if</span> ba[<span class="str">"winner"</span>] == <span class="str">"A"</span> <span class="kw">else</span> <span class="str">"tie"</span>)}
        results.extend([ab[<span class="str">"winner"</span>], ba_normalised[<span class="str">"winner"</span>]])

    wins_a = results.count(<span class="str">"A"</span>)
    wins_b = results.count(<span class="str">"B"</span>)
    <span class="kw">return</span> {<span class="str">"A_wins"</span>: wins_a, <span class="str">"B_wins"</span>: wins_b, <span class="str">"ties"</span>: results.count(<span class="str">"tie"</span>)}`,

  verifier:`<span class="cm"># ── Verifier Pattern ────────────────────────────────────────────</span>
<span class="cm"># Binary or confidence-scored check — did the model get it right?</span>

<span class="kw">def</span> <span class="fn">build_verifier_prompt</span>(claim, reference=<span class="kw">None</span>, domain=<span class="str">"general"</span>):
    ref_block = <span class="str">f"\n\nREFERENCE KNOWLEDGE:\n{reference}"</span> <span class="kw">if</span> reference <span class="kw">else</span> <span class="str">""</span>
    <span class="kw">return</span> <span class="str">f"""You are a {domain} verification assistant.

CLAIM TO VERIFY:
{claim}{ref_block}

Evaluate whether the claim is correct.
Return ONLY valid JSON:
{{
  "verdict": "PASS" | "FAIL" | "UNCERTAIN",
  "confidence": <integer 0–100>,
  "reasoning": "<concise explanation>"
}}"""</span>

<span class="kw">def</span> <span class="fn">verify_claim</span>(claim, reference=<span class="kw">None</span>, domain=<span class="str">"general"</span>):
    prompt = build_verifier_prompt(claim, reference, domain)
    msg = client.messages.create(
        model=<span class="str">"claude-haiku-4-5-20251001"</span>,  <span class="cm"># cheaper for binary checks</span>
        max_tokens=<span class="num">256</span>,
        messages=[{<span class="str">"role"</span>: <span class="str">"user"</span>, <span class="str">"content"</span>: prompt}]
    )
    <span class="kw">return</span> json.loads(msg.content[<span class="num">0</span>].text)

<span class="cm"># ── Run a batch of verifications ─────────────────────────────────</span>
<span class="kw">def</span> <span class="fn">batch_verify</span>(claims_with_refs):
    <span class="kw">return</span> [
        {<span class="str">"claim"</span>: c[<span class="str">"claim"</span>], **verify_claim(c[<span class="str">"claim"</span>], c.get(<span class="str">"reference"</span>))}
        <span class="kw">for</span> c <span class="kw">in</span> claims_with_refs
    ]

<span class="cm"># ── Example ──────────────────────────────────────────────────────</span>
result = verify_claim(
    claim=<span class="str">"The Great Wall is visible from space."</span>,
    domain=<span class="str">"factual"</span>
)
<span class="cm"># → {"verdict": "FAIL", "confidence": 98, "reasoning": "..."}</span>`,

  tips:`<span class="cm"># ── Common Pitfalls & Best Practices ────────────────────────────</span>

<span class="cm"># 1. POSITION BIAS — judges favour response A over B</span>
<span class="cm">#    Fix: always run A/B AND B/A, take majority</span>

<span class="cm"># 2. VERBOSITY BIAS — judges favour longer responses</span>
<span class="cm">#    Fix: explicitly add "length should not affect score" to rubric</span>

<span class="cm"># 3. SELF-PREFERENCE — a model judges its own outputs more leniently</span>
<span class="cm">#    Fix: use a different (ideally stronger) model as the judge</span>

<span class="cm"># 4. PROMPT SENSITIVITY — small wording changes shift scores</span>
<span class="cm">#    Fix: lock the judge prompt; version control it; run calibration</span>

<span class="cm"># 5. STRUCTURED OUTPUT — avoid parsing free-text scores</span>
<span class="cm">#    Fix: always ask for JSON; use a schema validator</span>

<span class="kw">import</span> json, re

<span class="kw">def</span> <span class="fn">safe_parse_judge</span>(raw_text):
    <span class="str">"""Extract JSON even if model adds surrounding text."""</span>
    match = re.search(<span class="str">r'\{.*\}'</span>, raw_text, re.DOTALL)
    <span class="kw">if not</span> match:
        <span class="kw">raise</span> ValueError(<span class="str">"No JSON found in judge output"</span>)
    <span class="kw">return</span> json.loads(match.group())

<span class="cm"># 6. CALIBRATION — check judge agreement with humans</span>
<span class="cm">#    Fix: build a golden set (human-labelled), measure judge accuracy</span>

<span class="cm"># 7. TEMPERATURE — use 0 for deterministic judging</span>
msg = client.messages.create(
    model=<span class="str">"claude-opus-4-8"</span>,
    max_tokens=<span class="num">512</span>,
    temperature=<span class="num">0</span>,       <span class="cm"># ← always 0 for evals</span>
    messages=[...]
)`
};

/* ─── COMPONENTS ─── */

function ScoreBar({ score, color }) {
  const [width, setWidth] = useState(0);
  useEffect(() => { setTimeout(() => setWidth((score / 5) * 100), 80); }, [score]);
  return (
    <div style={{ background: "#e2e8f0", borderRadius: 99, height: 7, overflow: "hidden", flex: 1 }}>
      <div style={{
        width: `${width}%`, height: "100%", background: color, borderRadius: 99,
        transition: "width .8s cubic-bezier(.4,0,.2,1)"
      }} />
    </div>
  );
}

function VerdictBadge({ verdict }) {
  const map = {
    Pass:      { bg:"#f0fdf4", border:"#86efac", text:"#16a34a", icon:"✓" },
    Borderline:{ bg:"#fffbeb", border:"#fcd34d", text:"#b45309", icon:"~" },
    Fail:      { bg:"#fff5f7", border:"#fda4af", text:"#be123c", icon:"✗" },
    PASS:      { bg:"#f0fdf4", border:"#86efac", text:"#16a34a", icon:"✓" },
    FAIL:      { bg:"#fff5f7", border:"#fda4af", text:"#be123c", icon:"✗" },
    UNCERTAIN: { bg:"#fffbeb", border:"#fcd34d", text:"#b45309", icon:"?" },
  };
  const s = map[verdict] || map.Borderline;
  return (
    <span style={{ display:"inline-flex", alignItems:"center", gap:5,
      background:s.bg, border:`1.5px solid ${s.border}`, borderRadius:20,
      padding:"4px 12px", fontFamily:"'Nunito'", fontSize:12, fontWeight:700, color:s.text }}>
      <span>{s.icon}</span> {verdict}
    </span>
  );
}

